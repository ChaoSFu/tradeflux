# 数据库连接串（PostgreSQL）
# 本地开发（无密码）：postgresql://用户名@localhost/数据库名
# 带密码：postgresql://用户名:密码@localhost/数据库名
# 远程：postgresql://用户名:密码@主机:5432/数据库名
DATABASE_URL=postgresql+psycopg://chao@localhost/tradeflux

# API 前缀
API_PREFIX=/api

# 调试模式（True 时打印 SQL 语句）
DEBUG=False

# 应用名
APP_NAME=TradeFlux

# 允许跨域的前端地址
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
